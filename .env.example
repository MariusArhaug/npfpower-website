# Database driver: sqlite (default) | mysql | postgres
DATABASE_DRIVER=sqlite

# Local SQLite (default for development)
DATABASE_URL=file:local.db

# Turso (for production with SQLite)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# MySQL example
# DATABASE_DRIVER=mysql
# DATABASE_URL=mysql://user:password@localhost:3306/npf

# PostgreSQL example
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/npf

PORT=3000
